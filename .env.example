# TLDR; Example environment variables for local dev via docker-compose.
# TODO: Copy to `.env` and adjust credentials/ports for your machine.

# --------- Postgres ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=erims
POSTGRES_USER=erims
POSTGRES_PASSWORD=erims_password

# --------- MongoDB ----------
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_INITDB_DATABASE=erims
MONGO_INITDB_ROOT_USERNAME=erims
MONGO_INITDB_ROOT_PASSWORD=erims_password

# --------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_ENV=local
APP_NAME=erims-api
JWT_SECRET=change_me_in_env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=60

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
